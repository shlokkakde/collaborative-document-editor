# Vercel builds Vite env vars at deploy time.
# Point this at the externally hosted Django/Channels backend.
VITE_API_BASE_URL=https://your-backend.example.com

# Optional. Only set this if WebSockets live on a different origin.
# If omitted, the app derives wss:// from VITE_API_BASE_URL.
VITE_WS_BASE_URL=wss://your-backend.example.com
