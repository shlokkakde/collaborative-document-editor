DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL is used when DATABASE_URL is set. Leave unset to use SQLite for a quick local demo.
DATABASE_URL=postgresql://doc_editor:doc_editor@localhost:5432/doc_editor

# Optional. Leave unset to use the in-memory Channels layer for single-process local development.
REDIS_URL=redis://localhost:6379/0
